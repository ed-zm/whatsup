{
  "name": "@whatsup/auth-service",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "migrate": "npm run migrate:up",
    "migrate:create": "node-pg-migrate create -m migrations --migration-file-language js --migration-filename-format utc",
    "migrate:up": "node-pg-migrate up -m migrations -d DATABASE_URL --migrations-table pgmigrations",
    "migrate:down": "node-pg-migrate down 1 -m migrations -d DATABASE_URL --migrations-table pgmigrations",
    "migrate:redo": "node-pg-migrate redo 1 -m migrations -d DATABASE_URL --migrations-table pgmigrations",
    "migrate:dry-run": "node-pg-migrate up -m migrations -d DATABASE_URL --migrations-table pgmigrations --dry-run"
  },
  "dependencies": {
    "express": "^4.22.1",
    "jsonwebtoken": "^9.0.3",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.20.0",
    "redis": "^5.12.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.39",
    "@types/pg": "^8.20.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
